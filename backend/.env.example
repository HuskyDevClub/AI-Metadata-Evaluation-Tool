# Backend configuration for local development.
# Copy this file to backend/.env and fill in your values:
#   cp backend/.env.example backend/.env

# --- LLM credentials (required for eval runs) ---
# OpenAI-compatible endpoint + key used to generate metadata.
LLM_ENDPOINT=
LLM_API_KEY=
# Model used to generate metadata suggestions.
LLM_MODEL=
# Judge model used to score generations. Defaults to LLM_MODEL if unset.
# Set a different model to compare generation quality across generators.
JUDGE_LLM_MODEL=gpt-5-mini

# --- Socrata ---
# App token raises Socrata rate limits when fetching dataset metadata.
SOCRATA_APP_TOKEN=

# --- Server (optional) ---
# Port the backend listens on. Defaults to 8000 (matches the Vite dev proxy).
# PORT=8000
