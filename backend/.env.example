# Backend configuration for local development.
# Copy this file to backend/.env and fill in your values:
#   cp backend/.env.example backend/.env

# --- LLM credentials (required for eval runs) ---
# OpenAI-compatible endpoint + key used to generate metadata.
LLM_ENDPOINT=
LLM_API_KEY=
# Model used to generate metadata suggestions.
LLM_MODEL=
# Judge model used to score generations. Defaults to LLM_MODEL if unset.
# Set a different model to compare generation quality across generators.
JUDGE_LLM_MODEL=gpt-5-mini

# --- Socrata ---
# App token raises Socrata rate limits when fetching dataset metadata.
SOCRATA_APP_TOKEN=

# --- Prompts (required) ---
# Base URL of the AI-Metadata-Improvement-Tool backend (e.g. its Databricks App
# URL, or http://localhost:8000 when running that tool locally). The eval fetches
# the canonical prompt templates from {PROMPTS_SOURCE_URL}/api/prompts so it
# scores the exact prompts that tool ships. There is no bundled fallback: if this
# is unset or unreachable, eval runs fail with a clear error.
PROMPTS_SOURCE_URL=http://localhost:8000

# --- Server (optional) ---
# Port the backend listens on. Defaults to 8000 (matches the Vite dev proxy).
# PORT=8001
