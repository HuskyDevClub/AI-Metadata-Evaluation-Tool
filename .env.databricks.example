# Databricks deployment environment variables.
# Copy this file to .env.databricks and fill in your values:
#   cp .env.databricks.example .env.databricks

# --- Deployment configuration ---
DATABRICKS_APP_NAME=
DATABRICKS_WORKSPACE_PATH=

# Public Databricks App URL (e.g. https://myapp-id.databricksapps.com).
# Used as the canonical CORS origin by the backend.
FRONTEND_URL=https://your-databricks-app-url

# --- LLM configuration (required for eval runs) ---
LLM_ENDPOINT=https://your-endpoint.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=your-model-name
# Judge model used to score generations. Defaults to LLM_MODEL if unset.
JUDGE_LLM_MODEL=gpt-5-mini

# --- Socrata ---
# App token raises Socrata rate limits when fetching dataset metadata.
SOCRATA_APP_TOKEN=

# --- Prompts (optional) ---
# Base URL of the deployed AI-Metadata-Improvement-Tool. When set, the eval
# fetches its canonical prompt templates so it scores the exact shipping prompts.
# Leave empty to use the bundled copies. (Also wire it in app.yaml — see there.)
# PROMPTS_SOURCE_URL=https://your-main-tool-app-url
