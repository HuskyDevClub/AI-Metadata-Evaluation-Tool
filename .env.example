# Eval Backend Configuration
# Copy this file to .env and fill in your values.
# The eval backend runs as a separate service and requires LLM credentials.

# Eval server port (separate from main backend)
EVAL_PORT=8001

# Judge LLM model for evaluation (required for eval runs)
# Defaults to LLM_MODEL from backend/.env if not set.
# Set a different model to compare generation quality across models.
JUDGE_LLM_MODEL=gpt-5-mini
