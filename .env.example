# AI Metadata Evaluation Tool — configuration
# Copy this file to .env and fill in your values.

# --- LLM credentials (required for eval runs) ---
# OpenAI-compatible endpoint and API key used to generate metadata.
LLM_ENDPOINT=
LLM_API_KEY=
# Model used to generate metadata suggestions.
LLM_MODEL=
# Judge model used to score generations. Defaults to LLM_MODEL if unset.
# Set a different model to compare generation quality across models.
JUDGE_LLM_MODEL=gpt-5-mini

# --- Socrata (optional) ---
# App token for fetching dataset metadata from Socrata open-data portals.
SOCRATA_APP_TOKEN=

# --- Server ---
# Port the eval backend listens on.
EVAL_PORT=8001
