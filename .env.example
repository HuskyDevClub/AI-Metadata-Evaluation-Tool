# Frontend (Vite) environment variables.
# For backend configuration, see backend/.env.example

# Backend API URL
# - Leave empty for both local dev (Vite proxies /api/* to the backend on :8000)
#   and Databricks (the backend serves the frontend at the same origin).
# - Only set this if running the frontend against a non-proxied backend.
VITE_API_BASE_URL=
